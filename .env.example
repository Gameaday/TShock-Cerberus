# ==========================================
# CERBERUS AUTHENTICATION BRIDGE CONFIG
# ==========================================

# --- DISCORD BOT SETTINGS ---
DISCORD_TOKEN=your_bot_token_here
# Role mappings format: DiscordRoleID:TShockGroupName
ROLE_MAP=11111111:member,22222222:vip,33333333:owner

# --- SHARED DATABASE SETTINGS ---
# This path is inside the container. It maps to the shared_state volume.
DATABASE_PATH=/app/shared/cerberus.db

# --- TSHOCK PLUGIN SETTINGS ---
# The name of the holding group for unverified players
LIMBO_GROUP_NAME=guest_limbo
# The message shown to random players who try to join without linking
KICK_MESSAGE=Access Denied. Join our Discord to verify: https://discord.gg/yourlink